# Atlassian domain
ATLASSIAN_DOMAIN=your-domain.atlassian.net

# Jira
ENABLE_JIRA=false
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Confluence
ENABLE_CONFLUENCE=false
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# Bitbucket
ENABLE_BITBUCKET=false
BITBUCKET_EMAIL=your-email@example.com
BITBUCKET_API_TOKEN=your-bitbucket-api-token
BITBUCKET_WORKSPACE=your-workspace

# PostgreSQL — open-ended hosts, each with its own credentials, configured server-side.
# Add as many POSTGRES_URL_<HOST>_<ENV> vars as needed; agents only ever supply
# `host` and `environment` (and optional `db`) — credentials never leave the MCP server.
ENABLE_POSTGRES=false
POSTGRES_URL_MICROSERVICES_DEV=postgresql://user:password@microservices-dev-host:5432/dbname
POSTGRES_URL_MICROSERVICES_QA=postgresql://user:password@microservices-qa-host:5432/dbname
POSTGRES_URL_MICROSERVICES_UAT=postgresql://user:password@microservices-uat-host:5432/dbname
POSTGRES_URL_MICROSERVICES_PROD=postgresql://user:password@microservices-prod-host:5432/dbname
POSTGRES_URL_MERCHANT_DEV=postgresql://user:password@merchant-dev-host:5432/dbname
POSTGRES_URL_MERCHANT_QA=postgresql://user:password@merchant-qa-host:5432/dbname
POSTGRES_URL_MERCHANT_UAT=postgresql://user:password@merchant-uat-host:5432/dbname
POSTGRES_URL_MERCHANT_PROD=postgresql://user:password@merchant-prod-host:5432/dbname
POSTGRES_URL_OPENAPIPARTNER_DEV=postgresql://user:password@openapipartner-dev-host:5432/dbname
POSTGRES_URL_OPENAPIPARTNER_QA=postgresql://user:password@openapipartner-qa-host:5432/dbname
POSTGRES_URL_OPENAPIPARTNER_UAT=postgresql://user:password@openapipartner-uat-host:5432/dbname
POSTGRES_URL_OPENAPIPARTNER_PROD=postgresql://user:password@openapipartner-prod-host:5432/dbname

# Redis — configure only the environments you need
ENABLE_REDIS=false
REDIS_URL_DEV=redis://dev-host:6379/0
REDIS_URL_QA=redis://qa-host:6379/0
REDIS_URL_UAT=redis://uat-host:6379/0
REDIS_URL_PROD=redis://prod-host:6379/0

# Kafka — configure only the environments you need
ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS_DEV=dev-kafka-host:9092
KAFKA_SSL_ENABLED_DEV=false
KAFKA_BOOTSTRAP_SERVERS_QA=qa-kafka-host:9092
KAFKA_SSL_ENABLED_QA=false
KAFKA_BOOTSTRAP_SERVERS_UAT=uat-kafka-host:9093
KAFKA_SSL_ENABLED_UAT=true
KAFKA_BOOTSTRAP_SERVERS_PROD=prod-kafka-host:9093
KAFKA_SSL_ENABLED_PROD=true

# Figma
ENABLE_FIGMA=false
FIGMA_API_TOKEN=your-figma-personal-token

# Obsidian
ENABLE_OBSIDIAN=false
OBSIDIAN_API_KEY=your_api_key_here
OBSIDIAN_URL=https://host.docker.internal:27124

# Elasticsearch / APM — configure only the environments you need
ENABLE_ELASTICSEARCH=false
ELASTICSEARCH_URL_DEV=http://dev-host:9200
ELASTICSEARCH_API_KEY_DEV=
ELASTICSEARCH_USERNAME_DEV=
ELASTICSEARCH_PASSWORD_DEV=
ELASTICSEARCH_URL_QA=http://qa-host:9200
ELASTICSEARCH_API_KEY_QA=
ELASTICSEARCH_USERNAME_QA=
ELASTICSEARCH_PASSWORD_QA=
ELASTICSEARCH_URL_UAT=http://uat-host:9200
ELASTICSEARCH_API_KEY_UAT=
ELASTICSEARCH_USERNAME_UAT=
ELASTICSEARCH_PASSWORD_UAT=
ELASTICSEARCH_URL_PROD=http://prod-host:9200
ELASTICSEARCH_API_KEY_PROD=
ELASTICSEARCH_USERNAME_PROD=
ELASTICSEARCH_PASSWORD_PROD=

# Loki — configure only the environments you need.
# TOKEN sends Bearer auth. USERNAME/PASSWORD sends Basic auth. TENANT_ID sends X-Scope-OrgID.
ENABLE_LOKI=false
LOKI_URL_DEV=http://dev-loki:3100
LOKI_TOKEN_DEV=
LOKI_USERNAME_DEV=
LOKI_PASSWORD_DEV=
LOKI_TENANT_ID_DEV=
LOKI_URL_QA=http://qa-loki:3100
LOKI_TOKEN_QA=
LOKI_USERNAME_QA=
LOKI_PASSWORD_QA=
LOKI_TENANT_ID_QA=
LOKI_URL_UAT=http://uat-loki:3100
LOKI_TOKEN_UAT=
LOKI_USERNAME_UAT=
LOKI_PASSWORD_UAT=
LOKI_TENANT_ID_UAT=
LOKI_URL_PROD=http://prod-loki:3100
LOKI_TOKEN_PROD=
LOKI_USERNAME_PROD=
LOKI_PASSWORD_PROD=
LOKI_TENANT_ID_PROD=

# Tempo — configure only the environments you need.
# TOKEN sends Bearer auth. USERNAME/PASSWORD sends Basic auth. TENANT_ID sends X-Scope-OrgID.
ENABLE_TEMPO=false
TEMPO_URL_DEV=http://dev-tempo:3200
TEMPO_TOKEN_DEV=
TEMPO_USERNAME_DEV=
TEMPO_PASSWORD_DEV=
TEMPO_TENANT_ID_DEV=
TEMPO_URL_QA=http://qa-tempo:3200
TEMPO_TOKEN_QA=
TEMPO_USERNAME_QA=
TEMPO_PASSWORD_QA=
TEMPO_TENANT_ID_QA=
TEMPO_URL_UAT=http://uat-tempo:3200
TEMPO_TOKEN_UAT=
TEMPO_USERNAME_UAT=
TEMPO_PASSWORD_UAT=
TEMPO_TENANT_ID_UAT=
TEMPO_URL_PROD=http://prod-tempo:3200
TEMPO_TOKEN_PROD=
TEMPO_USERNAME_PROD=
TEMPO_PASSWORD_PROD=
TEMPO_TENANT_ID_PROD=
